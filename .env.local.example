NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL — REQUIRED for email confirmation redirects in production
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# AI Life Interviews (server-side only)
ANTHROPIC_API_KEY=

# Email (for invite notifications — optional, degrades gracefully)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@memorypalace.app

# Google Photos OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox OAuth (https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# OneDrive / Microsoft OAuth (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# Box OAuth (https://developer.box.com/guides/applications/)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
