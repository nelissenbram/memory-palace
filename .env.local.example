# Must be a Supabase project in eu-central-1 (Frankfurt) for GDPR compliance
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL — REQUIRED for email confirmation redirects in production
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# AI Life Interviews (server-side only)
ANTHROPIC_API_KEY=

# Email (for invite notifications — optional, degrades gracefully)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@memorypalace.app

# Google Photos OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox OAuth (https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# OneDrive / Microsoft OAuth (https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# Box OAuth (https://developer.box.com/guides/applications/)
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=

# Stripe (https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Price IDs (create products in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_KEEPER_PRICE_ID=
NEXT_PUBLIC_STRIPE_GUARDIAN_PRICE_ID=
STRIPE_KEEPER_PRICE_ID=
STRIPE_GUARDIAN_PRICE_ID=

# Upstash Redis (https://console.upstash.com — distributed rate limiting)
# Use eu-central-1 region for GDPR compliance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push / VAPID (generate once via: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@thememorypalace.ai

# Cron secret (used by Vercel Cron to authenticate /api/notifications/send)
CRON_SECRET=
