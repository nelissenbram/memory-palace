{
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/textures/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/hdri/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/models/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/notifications/send",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/email/digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/legacy-check",
      "schedule": "2 9 * * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/kep-disclosure",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/pre-renewal",
      "schedule": "5 10 * * *"
    },
    {
      "path": "/api/cron/drip-and-reengage",
      "schedule": "30 9 * * *"
    }
  ]
}
