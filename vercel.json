{
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/notifications/send",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/email/digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/legacy-check",
      "schedule": "0 9 * * *"
    }
  ]
}
